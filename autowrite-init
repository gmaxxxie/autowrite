- 阅读动机：
BSEOF

  # 创建 workflow-state.json 初始状态
  python3 "$AUTOWRITE_ROOT/scripts/autowrite-state" set "$TARGET_DIR" project init done 2>/dev/null || true

  success "书籍工作区创建完成: $TARGET_DIR"
  echo ""
  echo "下一步:"
  echo "  cd $TARGET_DIR"
  echo "  autowrite write next $BOOK_NAME"
  echo ""
}

