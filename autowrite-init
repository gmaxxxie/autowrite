#!/bin/bash
# autowrite-init - 初始化书籍工作区 + 真相文件
# 用法: autowrite init <书名> --genre <题材> [--path <路径>]

set -e

init_usage() {
  cat << EOF
用法: autowrite init <书名> --genre <题材> [--path <路径>]

初始化一个新书籍工作区，包含：
- 书籍目录结构
- 7 个真相文件（非小说适配版）
- 项目配置文件

示例:
  autowrite init "AI教育" --genre non-fiction
  autowrite init "我的书" --genre non-fiction --path ~/my-books
EOF
}

cmd_init() {
  local BOOK_NAME=""
  local GENRE="non-fiction"
  local TARGET_DIR=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --genre)
        GENRE="$2"
        shift 2
        ;;
      --path)
        TARGET_DIR="$2"
        shift 2
        ;;
      --help|-h)
        init_usage
        exit 0
        ;;
      *)
        if [[ -z "$BOOK_NAME" ]]; then
          BOOK_NAME="$1"
        fi
        shift
        ;;
    esac
  done

  if [[ -z "$BOOK_NAME" ]]; then
    error "请提供书名"
    init_usage
    exit 1
  fi

  # 确定目标目录
  if [[ -z "$TARGET_DIR" ]]; then
    TARGET_DIR="$BOOKS_DIR/$BOOK_NAME"
  fi

  # 检查是否已存在
  if [[ -d "$TARGET_DIR" ]]; then
    error "书籍目录已存在: $TARGET_DIR"
    exit 1
  fi

  info "初始化书籍: $BOOK_NAME"
  info "目录: $TARGET_DIR"
  info "题材: $GENRE"

  # 用 scaffold_book_project.py 创建标准目录结构
  SCAFFOLD_SCRIPT="$AUTOWRITE_ROOT/book-writing-skills/skills/book-project-workspace/scripts/scaffold_book_project.py"
  if [[ -f "$SCAFFOLD_SCRIPT" ]]; then
    if python3 "$SCAFFOLD_SCRIPT" "$TARGET_DIR" \
      --book-title "$BOOK_NAME" \
      --category "$GENRE" 2>&1; then
      success "脚手架模板已创建"
    else
      warn "脚手架脚本失败，使用基础目录结构"
    fi
  fi

  # 确保关键目录存在（scaffold 可能因缺少模板而跳过部分）
  mkdir -p "$TARGET_DIR/truth"
  mkdir -p "$TARGET_DIR/00-index"
  mkdir -p "$TARGET_DIR/01-原始素材"
  mkdir -p "$TARGET_DIR/02-概念卡"
  mkdir -p "$TARGET_DIR/03-案例库"
  mkdir -p "$TARGET_DIR/04-书稿/CN"
  mkdir -p "$TARGET_DIR/04-书稿/EN"
  mkdir -p "$TARGET_DIR/05-章节草稿/CN"
  mkdir -p "$TARGET_DIR/05-章节草稿/EN"
  mkdir -p "$TARGET_DIR/06-出版版准备/封面"
  mkdir -p "$TARGET_DIR/06-出版版准备/图表"
  mkdir -p "$TARGET_DIR/06-出版版准备/00-运营资产包"
  mkdir -p "$TARGET_DIR/07-发布/CN"
  mkdir -p "$TARGET_DIR/07-发布/EN"
  mkdir -p "$TARGET_DIR/08-翻译"

  # 创建项目配置
  cat > "$TARGET_DIR/book.conf" << EOF
# AutoWriteO 书籍配置文件
# 此文件自动生成，请勿手动修改格式

BOOK_NAME="$BOOK_NAME"
GENRE="$GENRE"
CREATED_AT="$(date -Iseconds)"
CHAPTER_TARGET=12
CHAPTER_WORDS_TARGET=2000
CURRENT_CHAPTER=0

# 真相文件路径
TRUTH_DIR="$TARGET_DIR/truth"
EOF

  # 创建 7 个真相文件（非小说适配版）
  create_truth_files "$TARGET_DIR"

  # 创建 book-structure.md（G1 门禁必需）
  mkdir -p "$TARGET_DIR/00-index"
  cat > "$TARGET_DIR/00-index/book-structure.md" << BSEOF
# 书籍结构

## 基本信息
- 书名：$BOOK_NAME
- 题材：$GENRE
- 目标读者：（待补充）
- 目标章数：12
- 每章目标字数：~2000字

## 章节规划

| 章节 | 标题 | 核心论点 | 预估字数 | 状态 |
|------|------|----------|----------|------|
| ch01 | （待规划） | （待规划） | ~2000字 | 待写 |
| ch02 | （待规划） | （待规划） | ~2000字 | 待写 |
| ch03 | （待规划） | （待规划） | ~2000字 | 待写 |
| ch04 | （待规划） | （待规划） | ~2000字 | 待写 |
| ch05 | （待规划） | （待规划） | ~2000字 | 待写 |
| ch06 | （待规划） | （待规划） | ~2000字 | 待写 |
| ch07 | （待规划） | （待规划） | ~2000字 | 待写 |
| ch08 | （待规划） | （待规划） | ~2000字 | 待写 |
| ch09 | （待规划） | （待规划） | ~2000字 | 待写 |
| ch10 | （待规划） | （待规划） | ~2000字 | 待写 |
| ch11 | （待规划） | （待规划） | ~2000字 | 待写 |
| ch12 | （待规划） | （待规划） | ~2000字 | 待写 |

