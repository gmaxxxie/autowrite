#!/bin/bash
# autowrite-validate - book.conf schema 校验
# 用法:
#   autowrite-validate <书籍目录>
#   autowrite-validate --conf <book.conf路径>
#
# 检查项:
#   - 必填字段存在
#   - 字段值格式合法
#   - 数值字段范围合理
#   - 路径字段指向有效位置

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

REQUIRED_FIELDS=(
  "BOOK_NAME"
  "GENRE"
  "CREATED_AT"
  "CHAPTER_TARGET"
  "CURRENT_CHAPTER"
  "TRUTH_DIR"
)

NUMERIC_FIELDS=(
  "CHAPTER_TARGET"
  "CURRENT_CHAPTER"
  "CHAPTER_WORDS_TARGET"
)

PATH_FIELDS=(
  "TRUTH_DIR"
)

VALID_GENRES=(
  "non-fiction"
  "fiction"
  "textbook"
  "memoir"
  "self-help"
  "business"
  "technology"
  "education"
  "science"
  "philosophy"
)

conf_val() {
  local CONF="$1"
  local KEY="$2"
  grep "^${KEY}=" "$CONF" 2>/dev/null | head -1 | cut -d= -f2- | sed "s/^\"//;s/\"$//" | sed "s/^'//;s/'$//"
}

has_field() {
  local CONF="$1"
  local KEY="$2"
  grep -q "^${KEY}=" "$CONF" 2>/dev/null
}

cmd_validate() {
  local CONF_PATH=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --conf)
        CONF_PATH="$2"
        shift 2
        ;;
      --help|-h)
        echo "用法: autowrite-validate [--conf <book.conf路径>] [<书籍目录>]"
        echo ""
        echo "校验 book.conf 的 schema 完整性。"
        return 0
        ;;
      *)
        if [[ -z "$CONF_PATH" ]]; then
          if [[ -d "$1" ]]; then
            CONF_PATH="$1/book.conf"
          elif [[ -f "$1" ]]; then
            CONF_PATH="$1"
          fi
        fi
        shift
        ;;
    esac
  done

  if [[ -z "$CONF_PATH" ]]; then
    if [[ -f "$PWD/book.conf" ]]; then
      CONF_PATH="$PWD/book.conf"
    else
      echo -e "${RED}[✗]${NC} 未找到 book.conf" >&2
      return 1
    fi
  fi

  if [[ ! -f "$CONF_PATH" ]]; then
    echo -e "${RED}[✗]${NC} 文件不存在: $CONF_PATH" >&2
    return 1
  fi

  local ERRORS=0
  local WARNINGS=0
  local BOOK_DIR
  BOOK_DIR="$(dirname "$CONF_PATH")"

  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "  book.conf Schema 校验"
  echo "  文件: $CONF_PATH"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""

  echo -e "${GREEN}[1] 必填字段检查${NC}"
  for FIELD in "${REQUIRED_FIELDS[@]}"; do
    if has_field "$CONF_PATH" "$FIELD"; then
      local VAL
      VAL="$(conf_val "$CONF_PATH" "$FIELD")"
      if [[ -z "$VAL" ]]; then
        echo -e "  ${RED}✗${NC} $FIELD: 值为空"
        ERRORS=$((ERRORS + 1))
      else
        echo -e "  ${GREEN}✓${NC} $FIELD: $VAL"
      fi
    else
      echo -e "  ${RED}✗${NC} $FIELD: 缺失"
      ERRORS=$((ERRORS + 1))
    fi
  done
  echo ""

  echo -e "${GREEN}[2] 数值字段检查${NC}"
  for FIELD in "${NUMERIC_FIELDS[@]}"; do
    if has_field "$CONF_PATH" "$FIELD"; then
      local VAL
      VAL="$(conf_val "$CONF_PATH" "$FIELD")"
      if [[ "$VAL" =~ ^[0-9]+$ ]]; then
        local NUM_VAL=$((VAL + 0))
        case "$FIELD" in
          CHAPTER_TARGET)
            if [[ $NUM_VAL -lt 1 ]]; then
              echo -e "  ${RED}✗${NC} $FIELD: $VAL (必须 ≥1)"
              ERRORS=$((ERRORS + 1))
            elif [[ $NUM_VAL -gt 50 ]]; then
              echo -e "  ${YELLOW}!${NC} $FIELD: $VAL (超过50章，确认是否合理)"
              WARNINGS=$((WARNINGS + 1))
            else
              echo -e "  ${GREEN}✓${NC} $FIELD: $VAL"
            fi
            ;;
          CURRENT_CHAPTER)
            local TARGET
            TARGET="$(conf_val "$CONF_PATH" "CHAPTER_TARGET")"
            if [[ -n "$TARGET" ]] && [[ $NUM_VAL -gt $((TARGET + 0)) ]]; then
              echo -e "  ${YELLOW}!${NC} $FIELD: $VAL (超过 CHAPTER_TARGET=$TARGET)"
              WARNINGS=$((WARNINGS + 1))
            else
              echo -e "  ${GREEN}✓${NC} $FIELD: $VAL"
            fi
            ;;
          CHAPTER_WORDS_TARGET)
            if [[ $NUM_VAL -lt 500 ]]; then
              echo -e "  ${YELLOW}!${NC} $FIELD: $VAL (每章 <500 字可能偏少)"
              WARNINGS=$((WARNINGS + 1))
            else
              echo -e "  ${GREEN}✓${NC} $FIELD: $VAL"
            fi
            ;;
          *)
            echo -e "  ${GREEN}✓${NC} $FIELD: $VAL"
            ;;
        esac
      else
        echo -e "  ${RED}✗${NC} $FIELD: 非数值 '$VAL'"
        ERRORS=$((ERRORS + 1))
      fi
    fi
  done
  echo ""

  echo -e "${GREEN}[3] 路径字段检查${NC}"
  for FIELD in "${PATH_FIELDS[@]}"; do
    if has_field "$CONF_PATH" "$FIELD"; then
      local VAL
      VAL="$(conf_val "$CONF_PATH" "$FIELD")"
      if [[ -d "$VAL" ]]; then
        echo -e "  ${GREEN}✓${NC} $FIELD: 存在"
      else
        echo -e "  ${YELLOW}!${NC} $FIELD: 目录不存在 ($VAL)"
        WARNINGS=$((WARNINGS + 1))
      fi
    fi
  done
  echo ""

  echo -e "${GREEN}[4] GENRE 合法性检查${NC}"
  local GENRE
  GENRE="$(conf_val "$CONF_PATH" "GENRE")"
  local GENRE_VALID=0
  for G in "${VALID_GENRES[@]}"; do
    if [[ "$GENRE" == "$G" ]]; then
      GENRE_VALID=1
      break
    fi
  done
  if [[ $GENRE_VALID -eq 1 ]]; then
    echo -e "  ${GREEN}✓${NC} GENRE: $GENRE"
  elif [[ -n "$GENRE" ]]; then
    echo -e "  ${YELLOW}!${NC} GENRE: '$GENRE' (非标准值，可用: ${VALID_GENRES[*]})"
    WARNINGS=$((WARNINGS + 1))
  fi
  echo ""

  echo -e "${GREEN}[5] 格式一致性检查${NC}"
  local BAD_LINES=0
  local LINE_NUM=0
  while IFS= read -r LINE; do
    LINE_NUM=$((LINE_NUM + 1))
    [[ -z "$LINE" ]] && continue
    [[ "$LINE" =~ ^#.*$ ]] && continue
    if [[ "$LINE" != *"="* ]]; then
      echo -e "  ${RED}✗${NC} 行 $LINE_NUM: 非键值对格式 '$LINE'"
      BAD_LINES=$((BAD_LINES + 1))
    fi
    local KEY="${LINE%%=*}"
    if [[ "$KEY" =~ [[:space:]] ]]; then
      echo -e "  ${YELLOW}!${NC} 行 $LINE_NUM: 键名含空格 '$KEY'"
      BAD_LINES=$((BAD_LINES + 1))
    fi
  done < "$CONF_PATH"
  if [[ $BAD_LINES -eq 0 ]]; then
    echo -e "  ${GREEN}✓${NC} 格式一致"
  else
    ERRORS=$((ERRORS + BAD_LINES))
  fi
  echo ""

  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  if [[ $ERRORS -eq 0 && $WARNINGS -eq 0 ]]; then
    echo -e "  ${GREEN}校验通过${NC}"
  elif [[ $ERRORS -eq 0 ]]; then
    echo -e "  ${YELLOW}校验通过（${WARNINGS} 个警告）${NC}"
  else
    echo -e "  ${RED}校验失败（${ERRORS} 个错误，${WARNINGS} 个警告）${NC}"
  fi
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""

  [[ $ERRORS -eq 0 ]]
}
