#!/usr/bin/env python3
"""
autowrite-state: 工作流状态机 — 读写 workflow-state.json

用法:
  autowrite-state get <书目录> <章节> <key>
  autowrite-state set <书目录> <章节> <key> <value>
  autowrite-state check-gate <书目录> <门禁名>
  autowrite-state check-audit-chain <书目录> <章节>
  autowrite-state check-prev-chapter <书目录> <章节>
  autowrite-state check-brief <书目录> <章节>
  autowrite-state show <书目录>

状态文件: <书目录>/00-index/workflow-state.json

结构:
{
  "ch01": {
    "brief": "done",          # done / blocked
    "draft": "done",          # done / blocked
    "auto-revisor": "done",   # done / blocked / skipped
    "quality-audit": "done",
    "de-ai-audit": "done",
    "cn-localization": "done",
    "persona-audit": "done",
    "revise": "done",
    "verdict": "pass"         # pass / revise / blocked
  },
  "project": {
    "g1_book_structure": "done",
    "g2_benchmark": "done",
    "g3_differentiation": "done",
    "g4_voice": "done",
    "g5_concepts": "done",
    "g6_cases": "done",
    "g7_voice_locked": "done",
    "g8_word_target": "done"
  }
}
"""

import json
import os
import sys
from pathlib import Path

