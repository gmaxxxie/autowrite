    },
}

GATE_ORDER = ["g1_book_structure", "g2_benchmark", "g3_differentiation",
              "g4_voice", "g5_concepts", "g6_cases", "g7_voice_locked", "g8_word_target"]

GATE_FIX = {
    "g1_book_structure": {
        "skill": "$book-project-workspace",
        "hint": "创建 00-index/book-structure.md（≥500 bytes）",
        "cmd": "autowrite fix <书名> g1",
    },
